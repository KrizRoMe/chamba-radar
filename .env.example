# ── LLM (MiniMax, pero swappable: cambia estas 3 vars para otro proveedor) ──
LLM_API_KEY=your_minimax_api_key_here
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M2.1

# ── ever-jobs API ────────────────────────────────────────────────────────────
EVER_JOBS_API_URL=http://localhost:3001

# ── WhatsApp (whatsapp-reminder-api / whareminder.com) ───────────────────────
# Base URL de tu API
WHAREMINDER_BASE_URL=https://api.whareminder.com

# API key (generada en GET /auth/api-keys)
WHAREMINDER_API_KEY=your_whareminder_api_key_here

# ID de tu sesión de WhatsApp conectada (GET /sessions → copia el id)
WHAREMINDER_SESSION_ID=your_session_id_here

# ID del template que tiene {{content}} en el mensaje (GET /sessions/:id/templates)
# Crea uno con: POST /sessions/:sessionId/templates
# Body: { "name": "job-digest", "message": "{{content}}" }
WHAREMINDER_TEMPLATE_ID=your_template_id_here

# ── Destino y preferencias ───────────────────────────────────────────────────
WHATSAPP_TARGET_PHONE=51986550234
TOP_N_RESULTS=5

# ── Archivos de perfil ───────────────────────────────────────────────────────
CV_PATH=data/cv.md
PREFERENCES_PATH=data/preferences.md

# ── Modo dry-run (no envía WhatsApp, solo imprime en consola) ────────────────
# DRY_RUN=1
